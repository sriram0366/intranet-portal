{
  "title": "NovaCorp Intranet Portal - System Health",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "target": "stats.gauges.node.cpu.usage_percent" }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "target": "stats.gauges.node.memory.used_mb" }
      ]
    },
    {
      "id": 3,
      "title": "Network Traffic (bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "target": "stats.counters.node.network.rx_bytes" },
        { "target": "stats.counters.node.network.tx_bytes" }
      ]
    },
    {
      "id": 4,
      "title": "Portal Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "target": "stats.gauges.intranet_portal.uptime_seconds" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s"
}
